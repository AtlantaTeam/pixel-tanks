{
    "defaultProfile": "playground",
    "common": {
        "active": true,
        "maxIterations": 10,
        "maxTurns": 200,
        "claudeTimeoutMs": 7200000,
        "authorAllowlist": ["Pelmenya"],
        "model": "claude-opus-4-8",
        "fallbackModel": "claude-opus-4-8",
        "permissionMode": "bypassPermissions",
        "blockedHealAttempts": 3,
        "gateHealAttempts": 2,
        "apiLimitMaxWaits": 3,
        "apiLimitGraceMin": 5,
        "deployCheck": {
            "workflow": "deploy.yml",
            "timeoutMs": 1200000,
            "pollIntervalMs": 15000,
            "healthUrl": "https://pixeltanks.ru",
            "healthTimeoutMs": 10000,
            "healthRetries": 3,
            "healthRetryDelayMs": 5000
        },
        "deadman": {
            "iterationGraceMs": 600000,
            "gateSilenceMs": 600000,
            "defaultSilenceMs": 300000
        },
        "modelRouting": {
            "default": "claude-opus-4-8",
            "labels": {
                "complexity:low": "claude-haiku-4-5-20251001",
                "complexity:medium": "claude-sonnet-5",
                "complexity:high": "claude-opus-4-8",
                "complexity:expert": "claude-fable-5"
            }
        },
        "review": {
            "default": "claude-opus-4-8",
            "escalated": "claude-fable-5",
            "fallback": "claude-opus-4-8",
            "escalateOn": [],
            "escalateOnPaths": [
                ".github/workflows/**",
                ".claude/ralph/**",
                "deploy/**",
                "scripts/**",
                "src/payload.config.ts",
                "src/payload/**",
                "src/app/(payload)/**",
                "**/middleware.ts",
                "next.config.ts"
            ],
            "maxTurns": 80,
            "diffLimit": 60000
        },
        "tunnelCheck": {
            "enabled": false,
            "proxyUrl": "http://127.0.0.1:8118",
            "ipCheckUrl": "https://api.ipify.org",
            "restartCmd": "systemctl restart shadowsocks-libev-local@frankfurt privoxy",
            "restartWaitMs": 3000
        },
        "prompt": "Прочитай .claude/ralph/ralph.md и строго следуй правилам оттуда. Возьми следующий открытый Issue из milestone '{milestone}' и реализуй его в ветке '{branch}'.",
        "phases": [
            {
                "milestone": "Непрерывный prod ralph · Фаза 2: включение флага в prod",
                "branch": "feature/ralph-continuous-prod-enable"
            }
        ]
    },
    "profiles": {
        "playground": {},
        "prod": {
            "haltBeforeDeploy": false
        }
    }
}
