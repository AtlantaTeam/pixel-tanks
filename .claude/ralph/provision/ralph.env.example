# Env прод-режима ralph. Скопировать в ralph.env, заполнить, положить на сервер (chmod 600).
# НЕ КОММИТИТЬ реальный ralph.env — только этот .example с плейсхолдерами.

# --- Claude Code (подписка Max) ---
# Получить на машине с браузером:  claude setup-token  → выдаст токен sk-ant-oat01-...
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-XXXXXXXX

# --- GitHub (для gh/git-операций ralph: PR, merge, push) ---
# PAT с scope repo, либо `gh auth token` с уже залогиненной машины (gho_...)
GH_TOKEN=gho_XXXXXXXX

# --- Прокси к Anthropic через Shadowsocks-туннель (Франкфурт) ---
# claude/node ходят в api.anthropic.com через privoxy(8118)→ss-local(1080)→Франкфурт.
# github/npm остаются напрямую из РФ (см. NO_PROXY).
HTTPS_PROXY=http://127.0.0.1:8118
HTTP_PROXY=http://127.0.0.1:8118
NODE_USE_ENV_PROXY=1
NO_PROXY=localhost,127.0.0.1,::1,github.com,api.github.com,codeload.github.com,objects.githubusercontent.com,registry.npmjs.org

# --- Shadowsocks-туннель (Outline-сервер вне РФ) — для provision.sh ---
# Все значения — из Outline Manager (access key ss://...). IP/порт/пароль — СЕКРЕТ, не светить.
SS_SERVER=<outline-server-ip>
SS_PORT=<outline-port>
SS_METHOD=chacha20-ietf-poly1305
SS_PASSWORD=<outline-password>

# --- Claude Code под root (VDS-песочница) ---
# На VDS всё под root, а `--permission-mode bypassPermissions` под root Claude Code
# блокирует («cannot be used with root/sudo privileges») — БЕЗ этого флага каждая
# ralph-сессия падает с кодом 1 за секунду, и breaker гасит loop (боевой случай
# 2026-07-20, первый AFK-прогон с прода). IS_SANDBOX=1 — штатный признак
# одноразовой VM/контейнера, снимает блокировку. На рабочей машине НЕ ставить.
IS_SANDBOX=1

# --- Health-check туннеля в ralph.js (#92) ---
# Включает egress-проверку перед каждой claude-сессией (локально/dev — не ставить).
# Ожидаемый egress берётся из RALPH_EXPECTED_EGRESS, иначе из SS_SERVER (выше).
RALPH_TUNNEL_CHECK=1
# Обычно НЕ нужен — egress и так совпадает с SS_SERVER выше. Раскомментировать только
# если ожидаемый IP отличается от SS_SERVER (напр. другой прокси перед Outline-сервером).
# RALPH_EXPECTED_EGRESS=<outline-server-ip>

# --- Telegram-нотифаер (бот→человек, #85) ---
# Токен бота — у @BotFather (/newbot). chat_id — свой личный ID (у @userinfobot)
# или ID группы/канала, куда бот добавлен админом. Односторонний канал: раннер
# только шлёт sendMessage, апдейты от бота не читает.
RALPH_TG_BOT_TOKEN=123456789:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RALPH_TG_CHAT_ID=123456789
