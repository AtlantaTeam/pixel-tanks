{
    "name": "pixel-tanks-web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --port 3050",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "lint:fsd": "steiger ./src",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "security:audit": "node scripts/security-audit.mjs",
        "test:count": "node scripts/test-count.mjs",
        "test:ratchet": "node scripts/test-ratchet.mjs",
        "test:only-detect": "node scripts/test-only-detect.mjs",
        "test:skip-detect": "node scripts/test-skip-detect.mjs",
        "project:sync": "node scripts/project-sync.mjs",
        "prepare": "husky"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@payloadcms/db-sqlite": "^3.84.1",
        "@payloadcms/next": "^3.84.1",
        "@payloadcms/richtext-lexical": "^3.84.1",
        "@tanstack/react-query": "^5.90.21",
        "clsx": "^2.1.1",
        "next": "^16.2.6",
        "payload": "^3.84.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-error-boundary": "^6.1.1",
        "react-hook-form": "^7.71.2",
        "react-toastify": "^11.0.5",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@feature-sliced/steiger-plugin": "^0.5.7",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/postcss": "^4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@vitest/coverage-v8": "^3.2.4",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^9",
        "eslint-config-next": "^16.2.6",
        "happy-dom": "^20.8.4",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.3",
        "prettier": "^3.8.1",
        "steiger": "^0.5.11",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vitest": "^3.2.4"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,css,md}": [
            "prettier --write"
        ]
    }
}
