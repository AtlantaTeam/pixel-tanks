# Скопируй в .env.local и заполни: cp .env.example .env.local

# Payload CMS — секрет для подписи JWT/cookies (любая длинная случайная строка)
PAYLOAD_SECRET=

# Строка подключения к БД: SQLite в dev, Postgres в prod
# dev:  file:./payload.db
# prod: postgres://user:password@host:5432/pocket_tanks
DATABASE_URI=file:./payload.db

# OpenAI API — генерация артов (скины, аватары), бэклог game-next. Пока не требуется
# OPENAI_API_KEY=
